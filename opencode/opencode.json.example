{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "openai": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "OpenAI",
      "options": {
        "baseURL": "${OPENAI_API_BASE}"
      },
      "models": {
        "gpt-4": {
          "name": "gpt-4"
        }
      }
    }
  },
  "model": "openai/gpt-4",
  "small_model": "openai/gpt-4"
}
